rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
          && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true
        )
        ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.profile.role == "admin"
          )
        )
      );
    }

    // ── Admins ──────────────────────────────────────────────────────────────
    // Only the admin themselves can read their own record. Nobody can write
    // (admin records are created manually in the Firebase Console).
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false;
    }

    // ── Product Catalog ─────────────────────────────────────────────────────
    // Public read so the storefront loads without sign-in.
    // Only admins can create, update, or delete products.
    match /catalog/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Users ───────────────────────────────────────────────────────────────
    // Customers can read and write only their own document and sub-collections.
    // Admins can read and update any user record (e.g. for customer support).
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      allow read, update: if isAdmin();
    }

    match /users/{userId}/{document=**} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }

    // ── Orders ──────────────────────────────────────────────────────────────
    // A signed-in customer can create an order and read their own orders.
    // Customers cannot update or delete orders after placement.
    // Admins can read all orders and update status (e.g. pending → shipped).
    match /orders/{orderId} {
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;
      allow read:   if isSignedIn()
                    && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if false;
    }

  }
}
