# Optional overrides (production on Vercel uses /api/* automatically)
VITE_OTP_SEND_ENDPOINT=
VITE_OTP_VERIFY_ENDPOINT=

# Vercel serverless OTP (Project → Settings → Environment Variables)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# OTP_HASH_SECRET=long-random-string
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=app-password
# OTP_FROM_EMAIL=your@gmail.com
# OTP_FROM_NAME=sanjiiiii
VITE_ADMIN_SECRET_KEY=your-strong-secret-here