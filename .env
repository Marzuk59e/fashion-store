# ─── OTP Email — Vercel (required for email sign-up) ─────────────────────────
# Set these in: Vercel → Project → Settings → Environment Variables
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# OTP_HASH_SECRET=long-random-string
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-gmail-app-password
# OTP_FROM_EMAIL=your@gmail.com
# OTP_FROM_NAME=Your Store Name

# ─── OTP Endpoints (optional override) ───────────────────────────────────────
# Only needed if you self-host the OTP API outside Vercel.
# Leave blank if deploying to Vercel — it uses /api/* automatically.
VITE_OTP_SEND_ENDPOINT=
VITE_OTP_VERIFY_ENDPOINT=
